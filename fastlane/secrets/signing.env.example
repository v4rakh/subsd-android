# Copy this file to signing.env and fill in real values.
# signing.env is never committed (see .gitignore).
#
# SUBSD_KEYSTORE_FILE: path to your .jks keystore file, relative to android/
# Place the keystore itself in fastlane/secrets/ so it stays out of git.

export SUBSD_KEYSTORE_FILE="fastlane/secrets/key.jks"
export SUBSD_KEYSTORE_PASSWORD="changeme"
export SUBSD_KEY_ALIAS="subsd"
export SUBSD_KEY_PASSWORD="changeme"
